---
import { createWhatsAppLink, defaultWhatsAppMessage } from '@utils/whatsapp';
---

<a
  class="focus-ring fixed bottom-5 right-5 z-50 inline-flex min-h-14 min-w-14 items-center justify-center gap-2 rounded-full bg-[#25D366] px-4 font-semibold text-white shadow-lg shadow-[#25D366]/25 transition-transform hover:scale-105 active:scale-95 sm:bottom-6 sm:right-6"
  href={createWhatsAppLink(defaultWhatsAppMessage('quiero informacion'))}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <img src="/images/whatsapp (2).png" alt="" class="size-7 object-contain" width="28" height="28" loading="lazy" />
  <span class="hidden text-sm sm:inline">WhatsApp</span>
</a>
