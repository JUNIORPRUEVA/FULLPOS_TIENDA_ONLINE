---
import { createWhatsAppLink, defaultWhatsAppMessage } from '@utils/whatsapp';
---

<a
  class="focus-ring fixed bottom-4 right-4 z-50 inline-flex min-h-14 min-w-14 items-center justify-center rounded-full bg-green-600 px-4 font-semibold text-white shadow-lg shadow-green-900/25 hover:bg-green-700 sm:bottom-6 sm:right-6"
  href={createWhatsAppLink(defaultWhatsAppMessage('quiero informacion'))}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <span class="hidden sm:inline">WhatsApp</span>
  <span class="sm:hidden">WA</span>
</a>
