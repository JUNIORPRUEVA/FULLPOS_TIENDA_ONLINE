---
import type { Offer } from '@app-types/index';
import { createWhatsAppLink } from '@utils/whatsapp';
import { Building2, Camera, ClipboardCheck, Cog, House, ShieldCheck, Wrench } from '@lucide/astro';
type Props = { offer: Offer };
const { offer } = Astro.props;
const isPhoto = offer.image.endsWith('.png') || offer.image.endsWith('.jpg') || offer.image.endsWith('.jpeg') || offer.image.endsWith('.webp');
const isProductPhoto = offer.image.includes('motor-porton-real');
const iconByOffer = offer.slug.includes('negocio')
  ? Building2
  : offer.slug.includes('casa')
    ? House
    : offer.slug.includes('motor')
      ? Cog
      : offer.slug.includes('mantenimiento')
        ? Wrench
        : offer.slug.includes('revision')
          ? ClipboardCheck
          : Camera;
const Icon = iconByOffer ?? ShieldCheck;
---

<article class="soft-card flex h-full flex-col overflow-hidden rounded-lg">
  <div class="relative grid aspect-[16/10] place-items-center overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-blue-950">
    <img src={offer.image} alt="" class={isPhoto ? (isProductPhoto ? 'h-full w-full object-contain p-3' : 'h-full w-full object-cover opacity-88') : 'h-20 w-20 sm:h-24 sm:w-24'} loading="lazy" width="320" height="220" />
    <span class="absolute left-3 top-3 grid size-10 place-items-center rounded-md bg-white/92 text-blue-700 shadow-sm">
      <Icon size={21} stroke-width={1.9} />
    </span>
  </div>
  <div class="flex flex-1 flex-col p-4 sm:p-5">
    <p class="text-sm font-semibold text-blue-700">{offer.priceLabel}</p>
    <h3 class="mt-2 text-lg font-semibold leading-snug text-slate-950 sm:text-xl">{offer.title}</h3>
    <p class="mt-2 text-sm leading-6 text-slate-600">{offer.subtitle}</p>
    <ul class="mt-4 space-y-2 text-sm text-slate-700">
      {offer.includes.slice(0, 3).map((item) => <li class="flex gap-2"><span class="text-green-600">&#10003;</span>{item}</li>)}
    </ul>
    <div class="mt-auto grid gap-2 pt-5">
      <a class="focus-ring touch-target inline-flex items-center justify-center rounded-md bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" href={`/ofertas/${offer.slug}`}>
        Ver detalle
      </a>
      <a class="focus-ring touch-target inline-flex items-center justify-center rounded-md border border-green-600 px-4 py-3 text-sm font-semibold text-green-700 hover:bg-green-50" href={createWhatsAppLink(offer.whatsappMessage)} target="_blank" rel="noopener noreferrer">
        Cotizar
      </a>
    </div>
  </div>
</article>
