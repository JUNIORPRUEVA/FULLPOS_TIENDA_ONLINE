---
import { siteConfig } from '@config/site';
import { createWhatsAppLink, defaultWhatsAppMessage } from '@utils/whatsapp';
import { Download, Menu, MessageCircle, X } from '@lucide/astro';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/categorias', label: 'Categorias' },
  { href: '/cotizar', label: 'Cotizar' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-[#05070d]/96 text-white shadow-lg shadow-slate-950/15 backdrop-blur">
  <div class="container-page flex min-h-16 items-center justify-between gap-3 py-2">
    <a href="/" class="focus-ring flex min-w-0 items-center gap-2 rounded-md" aria-label="Ir al inicio">
      <span class="grid size-11 shrink-0 place-items-center overflow-hidden rounded-md bg-white">
        <img src="/images/logo-fulltech-light.jpg" alt="" class="h-full w-full object-cover" width="44" height="44" />
      </span>
      <span class="leading-tight">
        <strong class="block text-sm font-semibold text-white">{siteConfig.shortName}</strong>
        <span class="block text-xs text-blue-100/80">Higuey, La Altagracia</span>
      </span>
    </a>
    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegacion principal">
      {navItems.map((item) => (
        <a class="focus-ring rounded-md px-3 py-2 text-sm font-medium text-slate-200 hover:bg-white/10 hover:text-white" href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden items-center gap-2 md:flex">
      <button id="install-app-button" class="focus-ring hidden min-h-11 items-center gap-2 rounded-md border border-blue-400/50 px-3 text-sm font-semibold text-blue-100 hover:bg-blue-500/15" type="button">
        <Download size={17} /> Instalar app
      </button>
      <a
        class="focus-ring touch-target inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm shadow-blue-900/30 hover:bg-blue-500"
        href={createWhatsAppLink(defaultWhatsAppMessage('quiero cotizar un servicio'))}
        target="_blank"
        rel="noopener noreferrer"
      >
        <MessageCircle size={17} /> WhatsApp
      </a>
    </div>
    <button id="drawer-open" class="focus-ring touch-target inline-grid place-items-center rounded-md border border-white/15 text-white md:hidden" type="button" aria-label="Abrir menu">
      <Menu size={24} />
    </button>
  </div>
</header>

<div id="mobile-drawer" class="fixed inset-0 z-50 hidden md:hidden" aria-hidden="true">
  <button id="drawer-backdrop" class="absolute inset-0 bg-slate-950/70 backdrop-blur-sm" type="button" aria-label="Cerrar menu"></button>
  <aside class="dark-shell absolute right-0 top-0 flex h-full w-[86vw] max-w-sm flex-col border-l border-white/10 p-5 text-white shadow-2xl">
    <div class="flex items-center justify-between gap-3">
      <a href="/" class="flex items-center gap-3">
        <img src="/images/logo-fulltech-light.jpg" alt="" class="size-12 rounded-md bg-white object-cover" width="48" height="48" />
        <span>
          <strong class="block font-semibold">{siteConfig.name}</strong>
          <span class="text-sm text-blue-100/75">Panel movil</span>
        </span>
      </a>
      <button id="drawer-close" class="touch-target grid place-items-center rounded-md border border-white/15" type="button" aria-label="Cerrar menu">
        <X size={22} />
      </button>
    </div>
    <nav class="mt-8 grid gap-2" aria-label="Menu movil">
      {navItems.map((item) => (
        <a class="drawer-link rounded-md border border-white/10 bg-white/5 px-4 py-4 text-base font-medium text-slate-100" href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="mt-auto grid gap-3 pt-8">
      <button id="install-app-button-mobile" class="touch-target inline-flex items-center justify-center gap-2 rounded-md border border-blue-300/60 bg-blue-500/15 px-4 py-3 font-semibold text-blue-50" type="button">
        <Download size={18} /> Instalar como app
      </button>
      <a class="touch-target inline-flex items-center justify-center gap-2 rounded-md bg-blue-600 px-4 py-3 font-semibold text-white" href={createWhatsAppLink(defaultWhatsAppMessage('quiero cotizar un servicio'))} target="_blank" rel="noopener noreferrer">
        <MessageCircle size={18} /> Cotizar por WhatsApp
      </a>
    </div>
  </aside>
</div>

<script is:inline>
  const drawer = document.getElementById('mobile-drawer');
  const openDrawer = document.getElementById('drawer-open');
  const closeDrawer = document.getElementById('drawer-close');
  const drawerBackdrop = document.getElementById('drawer-backdrop');
  const drawerLinks = document.querySelectorAll('.drawer-link');
  const installButtons = [
    document.getElementById('install-app-button'),
    document.getElementById('install-app-button-mobile'),
  ].filter(Boolean);
  let deferredInstallPrompt;

  function showDrawer() {
    drawer?.classList.remove('hidden');
    document.documentElement.classList.add('drawer-open');
  }

  function hideDrawer() {
    drawer?.classList.add('hidden');
    document.documentElement.classList.remove('drawer-open');
  }

  openDrawer?.addEventListener('click', showDrawer);
  closeDrawer?.addEventListener('click', hideDrawer);
  drawerBackdrop?.addEventListener('click', hideDrawer);
  drawerLinks.forEach((link) => link.addEventListener('click', hideDrawer));

  window.addEventListener('beforeinstallprompt', (event) => {
    event.preventDefault();
    deferredInstallPrompt = event;
    installButtons.forEach((button) => button.classList.remove('hidden'));
  });

  installButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      if (!deferredInstallPrompt) {
        alert('Para instalar en iPhone: abre Compartir y toca "Agregar a pantalla de inicio". En Android: usa el menu del navegador si no aparece el aviso.');
        return;
      }
      deferredInstallPrompt.prompt();
      await deferredInstallPrompt.userChoice;
      deferredInstallPrompt = null;
      installButtons.forEach((item) => item.classList.add('hidden'));
    });
  });
</script>
