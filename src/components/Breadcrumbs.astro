---
type Crumb = { label: string; href?: string };
type Props = { items: Crumb[] };
const { items } = Astro.props;
---

<nav class="container-page pt-6 text-sm text-slate-500" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    <li><a class="hover:text-blue-700" href="/">Inicio</a></li>
    {items.map((item) => (
      <>
        <li aria-hidden="true">/</li>
        <li>
          {item.href ? <a class="hover:text-blue-700" href={item.href}>{item.label}</a> : <span class="text-slate-800">{item.label}</span>}
        </li>
      </>
    ))}
  </ol>
</nav>
