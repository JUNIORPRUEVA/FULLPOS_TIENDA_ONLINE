---
import { createWhatsAppLink } from '@utils/whatsapp';
type Props = {
  title?: string;
  description?: string;
  message?: string;
  label?: string;
};
const {
  title = 'Quieres proteger tu casa o negocio hoy?',
  description = 'Escribenos por WhatsApp y te orientamos con una opcion realista para tu espacio.',
  message = 'Hola Fulltech, quiero proteger mi casa o negocio.',
  label = 'Cotizar por WhatsApp',
} = Astro.props;
---

<section class="bg-slate-950 py-12 text-white">
  <div class="container-page flex flex-col items-start justify-between gap-5 md:flex-row md:items-center">
    <div>
      <h2 class="text-2xl font-semibold leading-tight sm:text-3xl">{title}</h2>
      <p class="mt-3 max-w-2xl text-slate-200">{description}</p>
    </div>
    <a class="focus-ring touch-target inline-flex shrink-0 items-center justify-center rounded-md bg-green-600 px-5 py-3 font-semibold text-white hover:bg-green-700" href={createWhatsAppLink(message)} target="_blank" rel="noopener noreferrer">
      {label}
    </a>
  </div>
</section>
