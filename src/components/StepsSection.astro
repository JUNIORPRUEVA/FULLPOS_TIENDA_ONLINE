---
const steps = [
  { num: '01', title: 'Elige el servicio', desc: 'Revisa nuestras categorias y ofertas destacadas, o escribenos directo por WhatsApp con lo que necesitas.' },
  { num: '02', title: 'Solicita cotizacion', desc: 'Te enviamos una orientacion personalizada segun tu casa, negocio u oficina, sin compromiso.' },
  { num: '03', title: 'Coordinamos visita', desc: 'Validamos las condiciones del lugar, los equipos adecuados y la disponibilidad del tecnico.' },
  { num: '04', title: 'Instalamos y probamos', desc: 'Dejamos el sistema instalado, configurado y funcionando. Te explicamos todo antes de irnos.' },
];
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Como funciona</h2>
      <p class="mt-3 leading-7 text-slate-500">Te guiamos paso a paso desde tu consulta hasta la instalacion final.</p>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-4">
      {steps.map((step, i) => (
        <div class="relative">
          <div class="flex items-center gap-4 md:flex-col md:items-start">
            <span class="grid size-12 shrink-0 place-items-center rounded-xl bg-blue-600 text-lg font-bold text-white shadow-sm">
              {step.num}
            </span>
            <div>
              <h3 class="font-semibold text-slate-900">{step.title}</h3>
              <p class="mt-1 text-sm leading-6 text-slate-500">{step.desc}</p>
            </div>
          </div>
          {i < steps.length - 1 && (
            <div class="ml-6 mt-2 hidden h-0.5 w-full rounded-full bg-blue-200 md:block" aria-hidden="true"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
