---
import type { FAQItem } from '@app-types/index';
type Props = { items: FAQItem[]; title?: string };
const { items, title = 'Preguntas frecuentes' } = Astro.props;
---

<section class="section-pad bg-white">
  <div class="container-page">
    <h2 class="text-2xl font-semibold text-slate-950 sm:text-3xl">{title}</h2>
    <div class="mt-6 divide-y divide-slate-200 rounded-lg border border-slate-200">
      {items.map((item) => (
        <details class="group p-5">
          <summary class="cursor-pointer list-none font-semibold text-slate-950">
            <span>{item.question}</span>
          </summary>
          <p class="mt-3 leading-7 text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
