---
import { categories } from '@data/categories';
import { siteConfig } from '@config/site';
import { createWhatsAppLink, defaultWhatsAppMessage } from '@utils/whatsapp';
---

<footer class="dark-shell border-t border-blue-400/20 text-white">
  <div class="container-page grid gap-8 py-10 md:grid-cols-[1.2fr_1fr_1fr]">
    <div>
      <img src="/images/logo-fulltech-dark.jpg" alt={siteConfig.name} class="h-16 w-16 rounded-lg object-cover ring-1 ring-white/10" width="64" height="64" loading="lazy" />
      <strong class="mt-4 block text-lg font-semibold text-white">{siteConfig.name}</strong>
      <p class="mt-3 max-w-sm text-sm leading-6 text-slate-300">
        Soluciones de seguridad, instalacion de camaras, motores para portones y servicios tecnicos en Higuey.
      </p>
      <a class="mt-4 inline-flex rounded-md bg-blue-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950/30 hover:bg-blue-500" href={createWhatsAppLink(defaultWhatsAppMessage('necesito ayuda'))} target="_blank" rel="noopener noreferrer">
        Cotizar por WhatsApp
      </a>
    </div>
    <div>
      <strong class="text-sm font-semibold text-white">Categorias</strong>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        {categories.map((category) => (
          <li><a class="hover:text-blue-300" href={`/categorias/${category.slug}`}>{category.name}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <strong class="text-sm font-semibold text-white">Contacto</strong>
      <ul class="mt-3 space-y-2 text-sm text-slate-300">
        <li>{siteConfig.address}</li>
        <li>{siteConfig.phone}</li>
        <li>{siteConfig.schedule}</li>
        <li><a class="hover:text-blue-300" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-xs text-slate-400">
    <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Datos, precios y testimonios editables.</p>
  </div>
</footer>
