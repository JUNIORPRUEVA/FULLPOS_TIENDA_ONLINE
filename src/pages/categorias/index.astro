---
import Layout from '@layouts/Layout.astro';
import CategoryCard from '@components/CategoryCard.astro';
import CTASection from '@components/CTASection.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { categories } from '@data/categories';
---

<Layout title="Categorias de servicios y productos" description="Categorias de Fulltech SRL: camaras de seguridad, motores para portones, servicios tecnicos y productos tecnologicos en Higuey.">
  <Breadcrumbs items={[{ label: 'Categorias' }]} />
  <section class="section-pad bg-slate-50">
    <div class="container-page">
      <h1 class="text-3xl font-semibold text-slate-950 sm:text-4xl">Categorias</h1>
      <p class="mt-4 max-w-2xl leading-7 text-slate-600">Elige el tipo de solucion que necesitas y cotiza rapido por WhatsApp.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </div>
  </section>
  <CTASection />
</Layout>
