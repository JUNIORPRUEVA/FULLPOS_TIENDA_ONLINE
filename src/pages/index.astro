---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import CategoryCard from '@components/CategoryCard.astro';
import OfferCard from '@components/OfferCard.astro';
import BenefitCard from '@components/BenefitCard.astro';
import StepsSection from '@components/StepsSection.astro';
import CTASection from '@components/CTASection.astro';
import FAQ from '@components/FAQ.astro';
import { categories } from '@data/categories';
import { featuredOffers } from '@data/offers';
import { generalFaqs } from '@data/faqs';
import { testimonials } from '@data/testimonials';
---

<Layout title="Instalacion de camaras y motores de portones en Higuey" description="Fulltech SRL instala camaras de seguridad, motores para portones y sistemas de seguridad para casas y negocios en Higuey. Cotiza rapido por WhatsApp.">
  <Hero />
  <section class="section-pad premium-surface">
    <div class="container-page">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold text-slate-950 sm:text-3xl">Categorias principales</h2>
        <p class="mt-3 leading-7 text-slate-600">Soluciones preparadas para vender hoy y crecer luego hacia un catalogo completo.</p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </div>
  </section>
  <section id="ofertas" class="section-pad dark-shell text-white">
    <div class="container-page">
      <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <h2 class="text-2xl font-semibold text-white sm:text-3xl">Ofertas destacadas</h2>
          <p class="mt-3 max-w-2xl leading-7 text-slate-300">Paquetes iniciales para cotizar instalaciones de forma rapida.</p>
        </div>
        <a class="font-semibold text-blue-200 hover:text-white" href="/categorias">Ver categorias</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {featuredOffers.map((offer) => <OfferCard offer={offer} />)}
      </div>
    </div>
  </section>
  <section class="section-pad bg-white">
    <div class="container-page">
      <h2 class="text-2xl font-semibold text-slate-950 sm:text-3xl">Por que elegir Fulltech?</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <BenefitCard title="Instalacion profesional" description="Trabajo tecnico ordenado para que el sistema quede probado y funcional." />
        <BenefitCard title="Atencion local" description="Servicio en Higuey y zonas cercanas de La Altagracia." />
        <BenefitCard title="Configuracion en celular" description="Te ayudamos a visualizar tus camaras desde el telefono cuando aplica." />
        <BenefitCard title="Soporte despues" description="Orientacion despues de la instalacion para dudas, ajustes o revisiones." />
        <BenefitCard title="Equipos confiables" description="Opciones segun necesidad, presupuesto y condiciones del lugar." />
        <BenefitCard title="Cotizacion rapida" description="Formulario simple y WhatsApp visible para convertir desde anuncios." />
      </div>
    </div>
  </section>
  <StepsSection />
  <CTASection />
  <section class="section-pad premium-surface">
    <div class="container-page">
      <h2 class="text-2xl font-semibold text-slate-950 sm:text-3xl">Confianza local</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {testimonials.map((item) => (
          <article class="soft-card rounded-lg p-4 sm:p-5">
            <p class="leading-7 text-slate-700">"{item.quote}"</p>
            <strong class="mt-4 block font-semibold text-slate-950">{item.name}</strong>
            <span class="text-sm text-slate-500">{item.role}</span>
          </article>
        ))}
      </div>
    </div>
  </section>
  <FAQ items={generalFaqs} />
</Layout>
