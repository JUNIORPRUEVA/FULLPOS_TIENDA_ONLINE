---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import OfferCard from '@components/OfferCard.astro';
import CTASection from '@components/CTASection.astro';
import FAQ from '@components/FAQ.astro';
import { offers, getOfferBySlug, getOffersByCategory } from '@data/offers';
import { getCategoryBySlug } from '@data/categories';
import { generalFaqs } from '@data/faqs';
import { createWhatsAppLink } from '@utils/whatsapp';

export function getStaticPaths() {
  return offers.map((offer) => ({ params: { slug: offer.slug } }));
}

const offer = getOfferBySlug(Astro.params.slug ?? '')!;
const category = getCategoryBySlug(offer.categorySlug);
const related = getOffersByCategory(offer.categorySlug).filter((item) => item.slug !== offer.slug).slice(0, 3);
const isPhoto = offer.image.endsWith('.png') || offer.image.endsWith('.jpg') || offer.image.endsWith('.jpeg') || offer.image.endsWith('.webp');
const isProductPhoto = offer.image.includes('motor-porton-real');
---

<Layout title={offer.seoTitle} description={offer.seoDescription}>
  <Breadcrumbs items={[{ label: 'Categorias', href: '/categorias' }, { label: category?.name ?? 'Oferta', href: category ? `/categorias/${category.slug}` : undefined }, { label: offer.title }]} />
  <section class="section-pad bg-slate-50">
    <div class="container-page grid gap-8 lg:grid-cols-[1fr_360px]">
      <div>
        <p class="font-semibold text-blue-700">{offer.priceLabel}</p>
        <h1 class="mt-3 text-3xl font-semibold leading-tight text-slate-950 sm:text-4xl">{offer.title}</h1>
        <p class="mt-4 text-lg leading-8 text-slate-600">{offer.description}</p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a class="touch-target inline-flex items-center justify-center rounded-md bg-green-600 px-5 py-3 font-semibold text-white hover:bg-green-700" href={createWhatsAppLink(offer.whatsappMessage)} target="_blank" rel="noopener noreferrer">
            {offer.title.includes('Motor') ? 'Quiero automatizar mi porton' : 'Quiero cotizar este kit'}
          </a>
          <a class="touch-target inline-flex items-center justify-center rounded-md border border-blue-600 px-5 py-3 font-semibold text-blue-700 hover:bg-blue-50" href="/cotizar">
            Reservar o cotizar
          </a>
        </div>
      </div>
      <aside class="soft-card rounded-lg p-4 sm:p-5">
        <div class="mb-5 grid aspect-[4/3] place-items-center overflow-hidden rounded-lg bg-slate-950">
          <img src={offer.image} alt="" class={isPhoto ? (isProductPhoto ? 'h-full w-full object-contain p-3' : 'h-full w-full object-cover') : 'size-28'} width="420" height="315" />
        </div>
        <h2 class="font-semibold text-slate-950">Incluye</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-700">
          {offer.includes.map((item) => <li class="flex gap-2"><span class="text-green-600">&#10003;</span>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>
  <section class="section-pad bg-white">
    <div class="container-page grid gap-6 md:grid-cols-3">
      <article class="rounded-lg bg-slate-50 p-5">
        <h2 class="font-semibold text-slate-950">Ideal para</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-700">{offer.idealFor.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="rounded-lg bg-slate-50 p-5">
        <h2 class="font-semibold text-slate-950">Beneficios</h2>
        <ul class="mt-4 space-y-2 text-sm text-slate-700">{offer.benefits.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="rounded-lg bg-slate-50 p-5">
        <h2 class="font-semibold text-slate-950">Garantia</h2>
        <p class="mt-4 text-sm leading-6 text-slate-700">{offer.warranty}</p>
      </article>
    </div>
  </section>
  {related.length > 0 && (
    <section class="section-pad bg-slate-50">
      <div class="container-page">
        <h2 class="text-2xl font-semibold text-slate-950 sm:text-3xl">Ofertas relacionadas</h2>
        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {related.map((item) => <OfferCard offer={item} />)}
        </div>
      </div>
    </section>
  )}
  <CTASection title="Listo para coordinar?" message={offer.whatsappMessage} label="Solicitar por WhatsApp" />
  <FAQ items={[...(offer.faqs ?? []), ...generalFaqs.slice(1, 5)]} />
</Layout>
